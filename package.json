    "@types/node": "^18.0.0",
    "builtin-modules": "^3.2.0",
    "esbuild": "^0.28.0",
    "obsidian": "^1.13.1",
    "tslib": "2.6.0",
    "typescript": "5.0.4"
  },
  "dependencies": {
    "d3": "^7.8.5",
    "i18next": "^26.3.0"
  }
}
